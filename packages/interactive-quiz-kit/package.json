{
  "name": "@thanh01.pmt/interactive-quiz-kit",
  "version": "1.0.89",
  "description": "A comprehensive library for creating, managing, and playing interactive quizzes, with AI generation and SCORM support.",
  "keywords": [
    "react",
    "quiz",
    "scorm",
    "edtech",
    "typescript",
    "headless",
    "ai",
    "genkit"
  ],
  "author": "Thanh Pham <https://github.com/thanh01pmt>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/thanh01pmt/interactive-quiz-kit.git"
  },
  "sideEffects": [
    "**/i18n.ts"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./react-ui": {
      "import": {
        "types": "./dist/react-ui.d.ts",
        "default": "./dist/react-ui.mjs"
      },
      "require": {
        "types": "./dist/react-ui.d.cts",
        "default": "./dist/react-ui.cjs"
      }
    },
    "./ai": {
      "import": {
        "types": "./dist/ai.d.ts",
        "default": "./dist/ai.mjs"
      },
      "require": {
        "types": "./dist/ai.d.cts",
        "default": "./dist/ai.cjs"
      }
    },
    "./player": {
      "import": {
        "types": "./dist/player.d.ts",
        "default": "./dist/player.mjs"
      },
      "require": {
        "types": "./dist/player.d.cts",
        "default": "./dist/player.cjs"
      }
    },
    "./client-services": {
      "import": {
        "types": "./dist/client-services.d.ts",
        "default": "./dist/client-services.mjs"
      },
      "require": {
        "types": "./dist/client-services.d.cts",
        "default": "./dist/client-services.cjs"
      }
    },
    "./i18n": {
      "import": {
        "types": "./dist/i18n.d.ts",
        "default": "./dist/i18n.mjs"
      },
      "require": {
        "types": "./dist/i18n.d.cts",
        "default": "./dist/i18n.cjs"
      }
    },
    "./schemas": {
      "import": {
        "types": "./dist/schemas.d.ts",
        "default": "./dist/schemas.mjs"
      },
      "require": {
        "types": "./dist/schemas.d.cts",
        "default": "./dist/schemas.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build": "npm run clean && tsc --project tsconfig.json && tsup",
    "build:scorm:js": "tsup --config tsup.scorm.config.ts",
    "build:scorm:css": "tailwindcss -i ./src/styles/main.css -o ./scorm-bundle/styles.css --minify",
    "build:scorm": "npm run build:scorm:js && npm run build:scorm:css",
    "preview:build": "npm run build && npm run build:scorm && node preview/gen-quiz-data.mjs",
    "preview:start": "node preview/server.mjs",
    "preview": "npm run preview:build && node preview/server.mjs",
    "lint": "eslint . --ext .ts,.tsx",
    "test": "jest --passWithNoTests",
    "release": "bash scripts/publish.sh"
  },
  "dependencies": {
    "@codemirror/lang-cpp": "^6.0.2",
    "@codemirror/lang-javascript": "^6.2.2",
    "@codemirror/lang-python": "^6.1.6",
    "@codemirror/language": "^6.10.0",
    "@codemirror/legacy-modes": "^6.4.0",
    "@codemirror/state": "^6.4.1",
    "@codemirror/view": "^6.26.3",
    "@dnd-kit/modifiers": "^9.0.0",
    "@google/generative-ai": "^0.21.0",
    "@monaco-editor/react": "^4.7.0",
    "@tailwindcss/typography": "^0.5.16",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "codemirror": "^6.0.1",
    "fengari-web": "^0.1.4",
    "highlight.js": "^11.11.1",
    "i18next": "^23.11.5",
    "i18next-browser-languagedetector": "^7.2.1",
    "jszip": "^3.10.1",
    "katex": "^0.16.22",
    "monaco-editor": "^0.55.1",
    "p-retry": "^7.1.1",
    "path-browserify": "^1.0.1",
    "react-i18next": "^14.1.2",
    "scratchblocks": "^3.6.4",
    "tailwind-merge": "^2.3.0",
    "zod": "^3.23.8"
  },
  "peerDependencies": {
    "next": ">=14.0.0",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "@dnd-kit/core": "^6.1.0",
    "@dnd-kit/sortable": "^8.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@milkdown/kit": "^7.3.2",
    "@milkdown/react": "^7.3.2",
    "@prosemirror-adapter/react": "^0.1.0-next.12",
    "@radix-ui/react-accordion": "^1.2.0",
    "@radix-ui/react-alert-dialog": "^1.1.1",
    "@radix-ui/react-avatar": "^1.1.0",
    "@radix-ui/react-checkbox": "^1.1.1",
    "@radix-ui/react-dialog": "^1.1.1",
    "@radix-ui/react-dropdown-menu": "^2.1.1",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-menubar": "^1.1.1",
    "@radix-ui/react-popover": "^1.1.1",
    "@radix-ui/react-progress": "^1.1.0",
    "@radix-ui/react-radio-group": "^1.2.0",
    "@radix-ui/react-scroll-area": "^1.1.0",
    "@radix-ui/react-select": "^2.1.1",
    "@radix-ui/react-separator": "^1.1.0",
    "@radix-ui/react-slider": "^1.2.0",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-switch": "^1.1.0",
    "@radix-ui/react-tabs": "^1.1.0",
    "@radix-ui/react-toast": "^1.2.1",
    "@radix-ui/react-tooltip": "^1.1.2",
    "@tiptap/extension-code-block-lowlight": "^2.4.0",
    "@tiptap/extension-image": "^2.4.0",
    "@tiptap/extension-link": "^2.4.0",
    "@tiptap/react": "^2.4.0",
    "@tiptap/starter-kit": "^2.4.0",
    "@types/jest": "^30.0.0",
    "@types/minimatch": "^6.0.0",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-calendar-heatmap": "^1.9.0",
    "@types/react-dom": "^18",
    "@uiw/react-codemirror": "^4.22.2",
    "autoprefixer": "^10.4.19",
    "date-fns": "^3.6.0",
    "dotenv": "^16.4.5",
    "eslint": "^8.57.0",
    "eslint-config-next": "14.2.3",
    "genkit-cli": "^1.8.0",
    "html-to-image": "^1.11.11",
    "jest": "^30.3.0",
    "lowlight": "^3.1.0",
    "lucide-react": "^0.395.0",
    "postcss": "^8.4.38",
    "react": "^18.3.1",
    "react-calendar-heatmap": "^1.10.0",
    "react-day-picker": "^8.10.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.52.0",
    "react-markdown": "^9.1.0",
    "react-tooltip": "^5.27.0",
    "recharts": "^2.12.7",
    "rehype-highlight": "^7.0.2",
    "rehype-katex": "^7.0.1",
    "rehype-raw": "^7.0.0",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "tailwindcss": "^3.4.1",
    "tailwindcss-animate": "^1.0.7",
    "ts-jest": "^29.4.6",
    "tsup": "^8.1.0",
    "typescript": "^5.9.2",
    "unist-util-visit": "^5.0.0"
  }
}
