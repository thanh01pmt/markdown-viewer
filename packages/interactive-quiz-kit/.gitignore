# .npmignore
# Thư mục mã nguồn, không cần cho người dùng cuối
/src/tracked_files
/src/tracked_files/*

# Các file cấu hình và phát triển
/.vscode
/tracked_files
/tracked_files/*
/dist

# Các file log và môi trường
*.log
.env*

# node_modules và các file lock
/node_modules
/package-lock.json
/yarn.lock
/pnpm-lock.yaml


# Các file hệ thống
.DS_Store