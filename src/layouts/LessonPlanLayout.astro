---
import MainLayout from './MainLayout.astro';
import { type CollectionEntry } from 'astro:content';

interface Props {
  lesson: CollectionEntry<'lessons'>;
}

const { lesson } = Astro.props;
const { title, description, duration, difficulty } = lesson.data;
---

<MainLayout title={title} description={description}>
  <div class="flex min-h-screen bg-slate-50 dark:bg-slate-900">
    <aside class="w-64 border-r border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-950 hidden md:block">
      <!-- Sidebar content will go here -->
      <div class="p-6">
        <h2 class="text-sm font-semibold text-slate-400 uppercase tracking-wider">Course Content</h2>
      </div>
    </aside>

    <main class="flex-1 overflow-auto">
      <article class="max-w-4xl mx-auto px-6 py-12">
        <header class="mb-12">
          <div class="flex items-center gap-2 mb-4 text-sm font-medium text-primary-600">
            {difficulty && (
              <span class="px-2 py-0.5 rounded-full bg-primary-50 dark:bg-primary-900/30">
                {difficulty.charAt(0).toUpperCase() + difficulty.slice(1)}
              </span>
            )}
            {duration && (
              <span class="flex items-center gap-1">
                <span>⏱️</span> {duration}
              </span>
            )}
          </div>
          <h1 class="text-4xl font-bold text-slate-900 dark:text-white mb-4 line-tight">{title}</h1>
          {description && <p class="text-xl text-slate-500 dark:text-slate-400">{description}</p>}
        </header>

        <div class="prose prose-slate prose-lg dark:prose-invert max-w-none">
          <slot />
        </div>
      </article>
    </main>
  </div>
</MainLayout>

<style>
  /* Custom prose styles if needed */
  .prose {
    --tw-prose-headings: var(--foreground);
    --tw-prose-links: oklch(0.627 0.265 303.891);
  }
</style>
