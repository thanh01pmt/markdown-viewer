---
import { getCollection } from 'astro:content';
import LessonLayout from '../../../layouts/LessonPlanLayout.astro';
import SlideLayout from '../../../layouts/SlideLayout.astro';
import ActivityLayout from '../../../layouts/LabLayout.astro'; // Fallback to LabLayout for activities

export async function getStaticPaths() {
  const lessonEntries = await getCollection('lessons');
  const slideEntries = await getCollection('slides');
  const activityEntries = await getCollection('activities');

  const paths = [
    ...lessonEntries.map(entry => {
      const parts = entry.id.split('/');
      const programId = parts[0];
      const slug = parts.slice(1).join('/').replace('.mdx', '');
      return {
        params: { programId, type: 'lessons', slug },
        props: { entry, contentType: 'lessons' }
      };
    }),
    ...slideEntries.map(entry => {
      const parts = entry.id.split('/');
      const programId = parts[0];
      const slug = parts.slice(1).join('/').replace('.mdx', '');
      return {
        params: { programId, type: 'slides', slug },
        props: { entry, contentType: 'slides' }
      };
    }),
    ...activityEntries.map(entry => {
      const parts = entry.id.split('/');
      const programId = parts[0];
      const slug = parts.slice(1).join('/').replace('.mdx', '');
      return {
        params: { programId, type: 'activities', slug },
        props: { entry, contentType: 'activities' }
      };
    }),
  ];

  return paths;
}

const { entry, contentType } = Astro.props;
const { Content } = await (entry as any).render();
---

{contentType === 'lessons' && (
  <LessonLayout lesson={entry}>
    <Content />
  </LessonLayout>
)}

{contentType === 'slides' && (
  <SlideLayout slide={entry} />
)}

{contentType === 'activities' && (
  <ActivityLayout lab={entry}>
    <Content />
  </ActivityLayout>
)}
