---
import { getCollection } from 'astro:content';
import LessonPlanLayout from '../layouts/LessonPlanLayout.astro';
import SlideLayout from '../layouts/SlideLayout.astro';
import QuizLayout from '../layouts/QuizLayout.astro';
import LabLayout from '../layouts/LabLayout.astro';

export async function getStaticPaths() {
  const lessonEntries = await getCollection('lessons');
  const slideEntries = await getCollection('slides');
  const quizEntries = await getCollection('quizzes');
  const labEntries = await getCollection('labs');

  const allEntries = [
    ...lessonEntries.map(entry => ({ params: { slug: `lessons/${entry.slug}` }, props: { entry, type: 'lesson' } })),
    ...slideEntries.map(entry => ({ params: { slug: `slides/${entry.slug}` }, props: { entry, type: 'slide' } })),
    ...quizEntries.map(entry => ({ params: { slug: `quizzes/${entry.slug}` }, props: { entry, type: 'quiz' } })),
    ...labEntries.map(entry => ({ params: { slug: `labs/${entry.slug}` }, props: { entry, type: 'lab' } })),
  ];

  return allEntries;
}

const { entry, type } = Astro.props;
const { Content } = await entry.render();
---

{type === 'lesson' && (
  <LessonPlanLayout lesson={entry}>
    <Content />
  </LessonPlanLayout>
)}

{type === 'slide' && (
  <SlideLayout slide={entry} />
)}

{type === 'quiz' && (
  <QuizLayout quiz={entry} />
)}

{type === 'lab' && (
  <LabLayout lab={entry}>
    <Content />
  </LabLayout>
)}
