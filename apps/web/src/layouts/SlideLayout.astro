---
import MainLayout from './MainLayout.astro';
import { type CollectionEntry } from 'astro:content';
import RevealSlides from '../components/slides/RevealSlides.astro';
import { Sidebar, type NavItem } from '../components/Navigation/Sidebar';

interface Props {
  slide: CollectionEntry<'slides'>;
  programId: string;
  lessons: NavItem[];
  slides: NavItem[];
  activities: NavItem[];
  currentSlug: string;
  rawContent?: string;
}

const { slide, programId, lessons, slides, activities, currentSlug, rawContent } = Astro.props;
const { title, description } = slide.data;
---

<MainLayout title={title} description={description}>
  <div class="flex h-screen w-screen overflow-hidden bg-slate-950">
    <Sidebar 
      client:load 
      programId={programId} 
      lessons={lessons} 
      slides={slides} 
      activities={activities} 
      currentSlug={currentSlug} 
    />
    <div class="flex-1 flex flex-col overflow-hidden">
    <header class="h-14 border-b border-slate-800 flex items-center justify-between px-6 bg-slate-900/50 backdrop-blur-md z-10">
      <h1 class="text-slate-200 font-medium text-sm truncate">{title}</h1>
      <div class="flex items-center gap-4">
        <button id="fullscreen-btn" class="text-slate-400 hover:text-white transition-colors text-xs uppercase tracking-widest font-semibold p-2">
          Fullscreen
        </button>
      </div>
    </header>

    <main class="flex-1 relative bg-black">
      <RevealSlides theme="night" rawContent={rawContent}>
        <slot />
      </RevealSlides>
    </main>
  </div>
</MainLayout>

<script>
  // Fullscreen toggle
  const btn = document.getElementById('fullscreen-btn');
  btn?.addEventListener('click', () => {
    if (!document.fullscreenElement) {
      document.documentElement.requestFullscreen();
    } else {
      if (document.exitFullscreen) {
        document.exitFullscreen();
      }
    }
  });

  // Load Reveal.js from CDN
  // @ts-ignore
  import Reveal from 'https://cdn.jsdelivr.net/npm/reveal.js@5.1.0/dist/reveal.esm.js';
  // @ts-ignore
  import Markdown from 'https://cdn.jsdelivr.net/npm/reveal.js@5.1.0/plugin/markdown/markdown.esm.js';
  // @ts-ignore
  import Highlight from 'https://cdn.jsdelivr.net/npm/reveal.js@5.1.0/plugin/highlight/highlight.esm.js';
  // @ts-ignore
  import Notes from 'https://cdn.jsdelivr.net/npm/reveal.js@5.1.0/plugin/notes/notes.esm.js';
  
  // Initialize Reveal.js
  Reveal.initialize({
    controls: true,
    progress: true,
    center: true,
    hash: true,
    transition: 'slide',
    plugins: [ Markdown, Highlight, Notes ],
    // Ensure it fits the container
    embedded: true,
  });
</script>

