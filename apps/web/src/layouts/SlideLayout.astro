---
import MainLayout from './MainLayout.astro';
import { type CollectionEntry } from 'astro:content';
import SlideRenderer from '../components/renderers/SlideRenderer';
import { Sidebar, type NavItem } from '../components/Navigation/Sidebar';

interface Props {
  slide: CollectionEntry<'slides'>;
  programId: string;
  lessons: NavItem[];
  slides: NavItem[];
  activities: NavItem[];
  currentSlug: string;
}

const { slide, programId, lessons, slides, activities, currentSlug } = Astro.props;
const { title, description } = slide.data;
---

<MainLayout title={title} description={description}>
  <div class="flex h-screen w-screen overflow-hidden bg-slate-950">
    <Sidebar 
      client:load 
      programId={programId} 
      lessons={lessons} 
      slides={slides} 
      activities={activities} 
      currentSlug={currentSlug} 
    />
    <div class="flex-1 flex flex-col overflow-hidden">
    <header class="h-14 border-b border-slate-800 flex items-center justify-between px-6 bg-slate-900/50 backdrop-blur-md z-10">
      <h1 class="text-slate-200 font-medium text-sm truncate">{title}</h1>
      <div class="flex items-center gap-4">
        <button id="fullscreen-btn" class="text-slate-400 hover:text-white transition-colors text-xs uppercase tracking-widest font-semibold p-2">
          Fullscreen
        </button>
      </div>
    </header>

    <main class="flex-1 relative">
      <SlideRenderer client:load content={slide.body} title={title} />
    </main>
  </div>
</MainLayout>

<script>
  const btn = document.getElementById('fullscreen-btn');
  btn?.addEventListener('click', () => {
    if (!document.fullscreenElement) {
      document.documentElement.requestFullscreen();
    } else {
      if (document.exitFullscreen) {
        document.exitFullscreen();
      }
    }
  });
</script>
