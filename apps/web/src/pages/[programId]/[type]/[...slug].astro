---
import { getCollection } from 'astro:content';
import LessonLayout from '../../../layouts/LessonPlanLayout.astro';
import SlideLayout from '../../../layouts/SlideLayout.astro';
import ActivityLayout from '../../../layouts/LabLayout.astro'; // Fallback to LabLayout for activities

export async function getStaticPaths() {
  const lessonEntries = await getCollection('lessons');
  const slideEntries = await getCollection('slides');
  const activityEntries = await getCollection('activities');

  const paths = [
    ...lessonEntries.map(entry => {
      const parts = entry.id.split('/');
      const programId = parts[0];
      const slug = parts.slice(1).join('/').replace('.mdx', '');
      const lessons = lessonEntries.filter(e => e.id.startsWith(programId + '/')).map(e => ({ title: e.data.title, slug: e.id.split('/').slice(1).join('/').replace('.mdx', ''), type: 'lessons' }));
      const slides = slideEntries.filter(e => e.id.startsWith(programId + '/')).map(e => ({ title: e.data.title, slug: e.id.split('/').slice(1).join('/').replace('.mdx', ''), type: 'slides' }));
      const activities = activityEntries.filter(e => e.id.startsWith(programId + '/')).map(e => ({ title: e.data.title, slug: e.id.split('/').slice(1).join('/').replace('.mdx', ''), type: 'activities' }));

      return {
        params: { programId, type: 'lessons', slug },
        props: { entry, contentType: 'lessons', programId, lessons, slides, activities, currentSlug: slug }
      };
    }),
    ...slideEntries.map(entry => {
      const parts = entry.id.split('/');
      const programId = parts[0];
      const slug = parts.slice(1).join('/').replace('.mdx', '');
      const lessons = lessonEntries.filter(e => e.id.startsWith(programId + '/')).map(e => ({ title: e.data.title, slug: e.id.split('/').slice(1).join('/').replace('.mdx', ''), type: 'lessons' }));
      const slides = slideEntries.filter(e => e.id.startsWith(programId + '/')).map(e => ({ title: e.data.title, slug: e.id.split('/').slice(1).join('/').replace('.mdx', ''), type: 'slides' }));
      const activities = activityEntries.filter(e => e.id.startsWith(programId + '/')).map(e => ({ title: e.data.title, slug: e.id.split('/').slice(1).join('/').replace('.mdx', ''), type: 'activities' }));

      return {
        params: { programId, type: 'slides', slug },
        props: { entry, contentType: 'slides', programId, lessons, slides, activities, currentSlug: slug }
      };
    }),
    ...activityEntries.map(entry => {
      const parts = entry.id.split('/');
      const programId = parts[0];
      const slug = parts.slice(1).join('/').replace('.mdx', '');
      const lessons = lessonEntries.filter(e => e.id.startsWith(programId + '/')).map(e => ({ title: e.data.title, slug: e.id.split('/').slice(1).join('/').replace('.mdx', ''), type: 'lessons' }));
      const slides = slideEntries.filter(e => e.id.startsWith(programId + '/')).map(e => ({ title: e.data.title, slug: e.id.split('/').slice(1).join('/').replace('.mdx', ''), type: 'slides' }));
      const activities = activityEntries.filter(e => e.id.startsWith(programId + '/')).map(e => ({ title: e.data.title, slug: e.id.split('/').slice(1).join('/').replace('.mdx', ''), type: 'activities' }));

      return {
        params: { programId, type: 'activities', slug },
        props: { entry, contentType: 'activities', programId, lessons, slides, activities, currentSlug: slug }
      };
    }),
  ];

  return paths;
}

const { entry, contentType, programId, lessons, slides, activities, currentSlug } = Astro.props;
const { Content } = await (entry as any).render();
---

{contentType === 'lessons' && (
  <LessonLayout 
    lesson={entry} 
    programId={programId} 
    lessons={lessons} 
    slides={slides} 
    activities={activities} 
    currentSlug={currentSlug}
  >
    <Content />
  </LessonLayout>
)}

{contentType === 'slides' && (
  <SlideLayout 
    slide={entry} 
    programId={programId} 
    lessons={lessons} 
    slides={slides} 
    activities={activities} 
    currentSlug={currentSlug}
  />
)}

{contentType === 'activities' && (
  <ActivityLayout 
    lab={entry} 
    programId={programId} 
    lessons={lessons} 
    slides={slides} 
    activities={activities} 
    currentSlug={currentSlug}
  >
    <Content />
  </ActivityLayout>
)}
