---
/**
 * RevealSlides - A simple wrapper component for Reveal.js presentations
 * 
 * This component provides the HTML structure for Reveal.js slides.
 * The initialization script is in the SlideLayout.
 * 
 * Dependencies: Reveal.js loaded from CDN
 */

interface Props {
	theme?: 'black' | 'white' | 'league' | 'beige' | 'sky' | 'night' | 'serif' | 'simple' | 'solarized' | 'blood' | 'moon';
	rawContent?: string;
}

const { theme = 'black', rawContent } = Astro.props;

// Strip Marp frontmatter, etc.
let processedContent = rawContent;
if (processedContent) {
	// Let's strip out slide-specific styles/frontmatter
	processedContent = processedContent.replace(/^---\n[\s\S]*?\n---\n/, '');
}
---

<!-- Reveal.js CSS from CDN -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/reveal.js@5.1.0/dist/reveal.css">
<link rel="stylesheet" href={`https://cdn.jsdelivr.net/npm/reveal.js@5.1.0/dist/theme/${theme}.css`}>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/reveal.js@5.1.0/plugin/highlight/monokai.css">

<div class="reveal">
	<div class="slides">
		{processedContent ? (
			<section 
				data-markdown 
				data-separator="^\r?\n---\r?\n$" 
				data-separator-vertical="^\r?\n--\r?\n$" 
				data-separator-notes="^<!-- notes:"
			>
				<script type="text/template" set:html={processedContent} />
			</section>
		) : (
			<slot />
		)}
	</div>
</div>

<style is:global>
	@import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Outfit:wght@500;600;700&display=swap');

	/* Ensure the presentation takes full viewport */
	.reveal-viewport {
		height: 100vh;
		width: 100vw;
		overflow: hidden;
		background: radial-gradient(circle at center, oklch(0.25 0.04 260) 0%, oklch(0.12 0.02 260) 100%);
	}
	
	/* Premium Typography Overrides */
	.reveal {
		font-family: 'Inter', system-ui, sans-serif !important;
		color: #cbd5e1 !important; /* slate-300 */
		font-size: 32px !important;
	}

	.reveal h1, .reveal h2, .reveal h3, .reveal h4 {
		font-family: 'Outfit', system-ui, sans-serif !important;
		text-transform: none !important;
		letter-spacing: -0.02em !important;
		font-weight: 700 !important;
		margin-bottom: 1rem !important;
	}

	.reveal h1 {
		font-size: 2.2em !important;
		background: linear-gradient(135deg, oklch(0.8 0.15 250) 0%, oklch(0.6 0.2 260) 100%) !important;
		-webkit-background-clip: text !important;
		-webkit-text-fill-color: transparent !important;
		text-shadow: 0 10px 30px rgba(0,0,0,0.3);
	}

	.reveal h2 {
		font-size: 1.6em !important;
		color: #e2e8f0 !important; /* slate-200 */
	}
	
	/* Section Alignments */
	.reveal .slides section {
		text-align: left;
		padding: 2rem !important;
	}
	
	.reveal .slides section > h1,
	.reveal .slides section > h2 {
		text-align: left;
	}
	
	/* Refined Code Blocks */
	.reveal pre code {
		max-height: 500px;
		border-radius: 12px !important;
		box-shadow: 0 10px 30px -10px rgba(0, 0, 0, 0.5) !important;
		font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace !important;
		padding: 1.5rem !important;
		font-size: 0.9em !important;
		line-height: 1.5 !important;
		border: 1px solid rgba(255,255,255,0.1);
	}

	/* Beautiful Blockquotes with Glassmorphism */
	.reveal blockquote {
		width: 100% !important;
		margin: 2rem 0 !important;
		padding: 2rem 2.5rem !important;
		border-left: 6px solid oklch(0.62 0.17 257) !important;
		background: rgba(255, 255, 255, 0.03) !important;
		backdrop-filter: blur(10px);
		border-radius: 4px 20px 20px 4px !important;
		box-shadow: 0 15px 35px rgba(0,0,0,0.2) !important;
		font-style: normal !important;
		color: #e2e8f0 !important;
		position: relative;
		overflow: hidden;
	}

	.reveal blockquote::before {
		content: '"';
		position: absolute;
		top: -20px;
		left: 10px;
		font-family: serif;
		font-size: 15rem;
		opacity: 0.05;
		color: white;
		pointer-events: none;
	}

	/* Lists */
	.reveal ul, .reveal ol {
		display: block !important;
		margin-bottom: 1.5rem !important;
	}

	.reveal li {
		margin-bottom: 0.75rem !important;
		line-height: 1.6 !important;
	}

	/* Controls & Progress bar */
	.reveal .controls {
		color: #64748b !important;
	}
	
	.reveal .progress {
		height: 4px !important;
		color: #38bdf8 !important;
	}

	/* Images */
	.reveal img {
		border-radius: 12px;
		box-shadow: 0 20px 40px -10px rgba(0,0,0,0.5);
		max-height: 60vh !important;
	}
</style>
